<div class="skj-combat-tracking-settings-form">
  <p class="hint">{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Intro"}}</p>

  <fieldset>
    <legend>{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Navigation.Name"}}</legend>
    <p class="hint">{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Navigation.Hint"}}</p>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.RequireAllCommit.Name"}}</label>
      <div class="form-fields">
        <input type="checkbox" name="requireAllCommit" value="true" data-dtype="Boolean" {{checked requireAllCommit}}>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.RequireAllCommit.Hint"}}</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Movement.Name"}}</legend>
    <p class="hint">{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Movement.Hint"}}</p>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.MovementRounding.Name"}}</label>
      <div class="form-fields">
        <select name="movementRounding">
          {{#each roundingChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.MovementRounding.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.MovementTickDelay.Name"}}</label>
      <div class="form-fields">
        <input type="number" name="movementTickDelayMs" value="{{movementTickDelayMs}}" min="{{limits.movementTickDelayMs.min}}" max="{{limits.movementTickDelayMs.max}}" step="{{limits.movementTickDelayMs.step}}" data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.MovementTickDelay.Hint"}}</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Reach.Name"}}</legend>
    <p class="hint">{{localize "AOV_SKJADLBORG.Settings.CombatTrackingMenu.Reach.Hint"}}</p>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.Reach.Short.Name"}}</label>
      <div class="form-fields">
        <input type="number" name="shortReachGridUnits" value="{{shortReachGridUnits}}" min="{{limits.reach.min}}" max="{{limits.reach.max}}" step="{{limits.reach.step}}" data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.Reach.Short.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.Reach.Medium.Name"}}</label>
      <div class="form-fields">
        <input type="number" name="mediumReachGridUnits" value="{{mediumReachGridUnits}}" min="{{limits.reach.min}}" max="{{limits.reach.max}}" step="{{limits.reach.step}}" data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.Reach.Medium.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.Reach.Long.Name"}}</label>
      <div class="form-fields">
        <input type="number" name="longReachGridUnits" value="{{longReachGridUnits}}" min="{{limits.reach.min}}" max="{{limits.reach.max}}" step="{{limits.reach.step}}" data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.Reach.Long.Hint"}}</p>
    </div>
  </fieldset>
</div>
