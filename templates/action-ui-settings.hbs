<div class="skj-action-ui-settings-form">
  <fieldset>
    <legend>{{localize "AOV_SKJADLBORG.Settings.ActionUiMenu.ActionRingGroup.Name"}}</legend>
    <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActionUiMenu.ActionRingGroup.Hint"}}</p>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActionRing.Name"}}</label>
      <div class="form-fields">
        <input type="checkbox" name="enableActionRing" value="true" data-dtype="Boolean" {{checked enableActionRing}}>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActionRing.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActionRingMaxItems.Name"}}</label>
      <div class="form-fields">
        <input
          type="number"
          name="actionRingMaxItems"
          value="{{actionRingMaxItems}}"
          min="{{limits.actionRingMaxItems.min}}"
          max="{{limits.actionRingMaxItems.max}}"
          step="{{limits.actionRingMaxItems.step}}"
          data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActionRingMaxItems.Hint"}}</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>{{localize "AOV_SKJADLBORG.Settings.ActionUiMenu.ActorHotbarGroup.Name"}}</legend>
    <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActionUiMenu.ActorHotbarGroup.Hint"}}</p>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActorHotbar.Name"}}</label>
      <div class="form-fields">
        <input type="checkbox" name="enableActorHotbar" value="true" data-dtype="Boolean" {{checked enableActorHotbar}}>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActorHotbar.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ReplaceCoreHotbar.Name"}}</label>
      <div class="form-fields">
        <input type="checkbox" name="replaceCoreHotbar" value="true" data-dtype="Boolean" {{checked replaceCoreHotbar}}>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ReplaceCoreHotbar.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActorHotbarScale.Name"}}</label>
      <div class="form-fields">
        <input
          type="number"
          name="actorHotbarScale"
          value="{{actorHotbarScale}}"
          min="{{limits.actorHotbarScale.min}}"
          max="{{limits.actorHotbarScale.max}}"
          step="{{limits.actorHotbarScale.step}}"
          data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActorHotbarScale.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActorHotbarActionWidth.Name"}}</label>
      <div class="form-fields">
        <input
          type="number"
          name="actorHotbarActionWidth"
          value="{{actorHotbarActionWidth}}"
          min="{{limits.actorHotbarActionWidth.min}}"
          max="{{limits.actorHotbarActionWidth.max}}"
          step="{{limits.actorHotbarActionWidth.step}}"
          data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActorHotbarActionWidth.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActorHotbarOpacity.Name"}}</label>
      <div class="form-fields">
        <input
          type="range"
          name="actorHotbarOpacity"
          value="{{actorHotbarOpacity}}"
          min="{{limits.actorHotbarOpacity.min}}"
          max="{{limits.actorHotbarOpacity.max}}"
          step="{{limits.actorHotbarOpacity.step}}"
          data-dtype="Number">
        <span class="range-value" data-actor-hotbar-opacity-value>{{actorHotbarOpacity}}%</span>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActorHotbarOpacity.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActionUiTheme.Name"}}</label>
      <div class="form-fields">
        <select name="actionUiTheme">
          {{#each themes}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActionUiTheme.Hint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOV_SKJADLBORG.Settings.ActorHotbarPosition.Name"}}</label>
      <div class="form-fields">
        <button type="button" data-action="resetPosition">
          <i class="fa-solid fa-location-crosshairs" inert></i>
          {{localize "AOV_SKJADLBORG.Settings.ActorHotbarPosition.Label"}}
        </button>
      </div>
      <p class="hint">{{localize "AOV_SKJADLBORG.Settings.ActorHotbarPosition.Hint"}}</p>
    </div>
  </fieldset>
</div>
