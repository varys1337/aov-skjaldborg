<div class="skj-roll-dialog skj-roll-dialog--attack skj-attack-roll-dialog">
  <header class="skj-roll-dialog__header skj-attack-roll-dialog__header">
    <div class="skj-roll-dialog__identity skj-attack-roll-dialog__identity">
      <div class="skj-roll-dialog__target-summary skj-attack-roll-dialog__target-summary">
        <span class="skj-roll-dialog__actor skj-attack-roll-dialog__actor">{{actorName}}</span>
        <div class="skj-roll-dialog__target-list" aria-label="{{localize "AOV_SKJALDBORG.AttackDialog.Target"}}">
          {{#each targets}}
          <button type="button" class="skj-roll-dialog__target-chip {{#if active}}is-active{{/if}}" data-target-key="{{key}}" title="{{name}}">
            <span class="skj-roll-dialog__target-portrait skj-attack-roll-dialog__target-portrait" aria-hidden="true">
              {{#if img}}
                {{#if imgIsVideo}}
                <video src="{{img}}" autoplay muted loop playsinline></video>
                {{else}}
                <img src="{{img}}" alt="" />
                {{/if}}
              {{else}}
              <i class="fa-solid fa-user-shield"></i>
              {{/if}}
            </span>
            <span>{{name}}</span>
          </button>
          {{else}}
          <span class="skj-roll-dialog__target-empty">{{localize "AOV_SKJALDBORG.TargetQueue.NoTargets"}}</span>
          {{/each}}
        </div>
      </div>
      <label class="skj-roll-dialog__control skj-attack-roll-dialog__weapon">
        <span>{{localize "AOV_SKJALDBORG.AttackDialog.Weapon"}}</span>
        <select name="weaponId" class="skj-roll-dialog__select skj-attack-roll-dialog__weapon-select">
          {{#each weapons}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      {{#if twoWeapon.enabled}}
      <label class="skj-attack-roll-dialog__two-weapon-toggle" data-tooltip="{{twoWeapon.halfSkillTooltip}}">
        <input
          type="checkbox"
          name="twoWeaponHalfSkill"
          aria-label="{{twoWeapon.halfSkillTooltip}}"
        />
        <span>{{localize "AOV_SKJALDBORG.AttackDialog.TwoWeaponHalfSkill"}}</span>
      </label>
      {{/if}}
      {{#if splitAttack.forced}}
      <div class="skj-attack-roll-dialog__split-forced">{{splitAttack.forcedLabel}}</div>
      {{else}}
        {{#if splitAttack.available}}
        <label class="skj-attack-roll-dialog__split-toggle" data-tooltip="{{localize "AOV_SKJALDBORG.SplitAttack.Hint"}}">
          <input type="checkbox" name="splitAttackEnabled" />
          <span>{{localize "AOV_SKJALDBORG.SplitAttack.Toggle"}}</span>
        </label>
        <div class="skj-attack-roll-dialog__split-fields" data-split-attack-fields hidden>
          <label>
            <span>{{localize "AOV_SKJALDBORG.SplitAttack.First"}}</span>
            <input type="number" name="splitFirstChance" min="50" step="1" value="{{splitAttack.first}}" />
          </label>
          <label>
            <span>{{localize "AOV_SKJALDBORG.SplitAttack.Second"}}</span>
            <input type="number" name="splitSecondChance" min="50" step="1" value="{{splitAttack.second}}" />
          </label>
        </div>
        {{else}}
        <div class="skj-attack-roll-dialog__split-unavailable" data-tooltip="{{splitAttack.unavailableHint}}">
          {{localize "AOV_SKJALDBORG.SplitAttack.Toggle"}}
        </div>
        {{/if}}
      {{/if}}
    </div>

    <div class="skj-roll-dialog__rating-card skj-attack-roll-dialog__target-card" data-tooltip="{{initialSummary}}" aria-label="{{initialSummary}}">
      <span class="skj-roll-dialog__label skj-attack-roll-dialog__target-label">{{localize "AOV_SKJALDBORG.AttackDialog.Attack"}}</span>
      <strong data-target-number>{{targetNumber}}%</strong>
      <span data-target-caption>{{localize "AOV_SKJALDBORG.AttackDialog.Modifiers.Standard"}}</span>
    </div>
  </header>

  <section class="skj-roll-dialog__body skj-attack-roll-dialog__body">
    <div class="skj-roll-dialog__row skj-roll-dialog__row--modifier skj-attack-roll-dialog__row skj-attack-roll-dialog__row--modifier">
      <label for="skj-attack-situational-modifier">{{localize "AOV_SKJALDBORG.AttackDialog.Situation"}}</label>
      <select id="skj-attack-situational-modifier" name="situationalModifier">
        {{#each modifiers}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}} ({{value}}%)</option>
        {{/each}}
      </select>
      <button
        type="button"
        class="skj-roll-dialog__damage-pill skj-attack-roll-dialog__damage {{#if damageTypeSelectable}}is-switchable{{else}}is-fixed{{/if}}"
        data-damage-type-control
        data-tooltip="{{damageTypeTooltip}}"
        aria-label="{{damageTypeTooltip}}"
        aria-disabled="{{#unless damageTypeSelectable}}true{{else}}false{{/unless}}"
      >
        <span class="skj-roll-dialog__damage-label skj-attack-roll-dialog__damage-label" data-weapon-damage-label>{{damageTypeLabel}}</span>
        <span class="skj-roll-dialog__damage-type skj-attack-roll-dialog__damage-type" data-weapon-damage-type>[{{damageType}}]</span>
        <span class="skj-roll-dialog__damage-formula skj-attack-roll-dialog__damage-formula" data-weapon-damage-formula>{{damage}}</span>
      </button>
      <input type="hidden" name="damageType" value="{{damageTypeKey}}" data-selected-damage-type>
    </div>

    <fieldset class="skj-roll-dialog__augment skj-attack-roll-dialog__fieldset">
      <legend>{{localize "AOV_SKJALDBORG.AttackDialog.Augmentation"}}</legend>
      <div class="skj-roll-dialog__segments skj-attack-roll-dialog__segments">
        <label class="skj-roll-dialog__segment skj-attack-roll-dialog__segment {{#unless hasAimedLocations}}is-disabled{{/unless}}" data-tooltip="{{aimedNoLocationsTooltip}}">
          <input type="checkbox" name="augmentOptions" value="aimed" {{#unless hasAimedLocations}}disabled{{/unless}} />
          <span>{{localize "AOV_SKJALDBORG.AttackDialog.Aimed"}}</span>
        </label>
        <label class="skj-roll-dialog__segment skj-attack-roll-dialog__segment {{#unless hasDisarmWeapons}}is-disabled{{/unless}}" data-tooltip="{{disarmNoWeaponsTooltip}}">
          <input type="checkbox" name="augmentOptions" value="disarm" {{#unless hasDisarmWeapons}}disabled{{/unless}} />
          <span>{{localize "AOV_SKJALDBORG.AttackDialog.Disarm"}}</span>
        </label>
        <label class="skj-roll-dialog__segment skj-attack-roll-dialog__segment {{#unless hasStunHead}}is-disabled{{/unless}}" data-tooltip="{{stunNoHeadTooltip}}">
          <input type="checkbox" name="augmentOptions" value="stun" {{#unless hasStunHead}}disabled{{/unless}} />
          <span>{{localize "AOV_SKJALDBORG.AttackDialog.Stun"}}</span>
        </label>
        <label class="skj-roll-dialog__segment skj-attack-roll-dialog__segment">
          <input type="checkbox" name="augmentOptions" value="custom" />
          <span>{{localize "AOV_SKJALDBORG.AttackDialog.Custom"}}</span>
        </label>
      </div>
    </fieldset>

    <section class="skj-roll-dialog__details skj-attack-roll-dialog__details">
      <div class="skj-roll-dialog__detail skj-attack-roll-dialog__detail skj-attack-roll-dialog__detail--aimed" data-augment-detail="aimed" hidden>
        <label>{{localize "AOV_SKJALDBORG.AttackDialog.AimedLocation"}}</label>
        <select name="aimedLocationId">
          {{#each aimedLocations}}
          <option value="{{value}}" data-target-kind="{{targetKind}}">{{label}}</option>
          {{/each}}
        </select>
        <div class="skj-attack-roll-dialog__aimed-penalty" role="radiogroup" aria-label="{{localize "AOV_SKJALDBORG.AttackDialog.AimedPenalty"}}">
          {{#each aimedPenalties}}
          <label class="skj-roll-dialog__segment skj-attack-roll-dialog__segment">
            <input type="radio" name="aimedPenalty" value="{{value}}" {{#if selected}}checked{{/if}} />
            <span>{{label}}</span>
          </label>
          {{/each}}
        </div>
      </div>

      <div class="skj-roll-dialog__detail skj-attack-roll-dialog__detail skj-attack-roll-dialog__detail--disarm" data-augment-detail="disarm" hidden>
        <label>{{localize "AOV_SKJALDBORG.AttackDialog.DisarmTargetWeapon"}}</label>
        <select name="disarmTargetWeaponId">
          {{#each disarmWeapons}}
          <option value="{{id}}">{{label}}</option>
          {{/each}}
        </select>
        <label>{{localize "AOV_SKJALDBORG.AttackDialog.DisarmMode"}}</label>
        <select name="disarmMode">
          {{#each disarmModes}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <div class="skj-attack-roll-dialog__disarm-controls">
          <label class="skj-attack-roll-dialog__toggle" data-tooltip="{{localize "AOV_SKJALDBORG.AttackDialog.DisarmTargetTwoHandedTooltip"}}">
            <input type="checkbox" name="disarmTargetTwoHanded" />
            <span>{{localize "AOV_SKJALDBORG.AttackDialog.DisarmTargetTwoHanded"}}</span>
          </label>
          <div class="skj-attack-roll-dialog__disarm-penalty" role="radiogroup" aria-label="{{localize "AOV_SKJALDBORG.AttackDialog.DisarmPenalty"}}">
            {{#each disarmPenalties}}
            <label class="skj-roll-dialog__segment skj-attack-roll-dialog__segment">
              <input type="radio" name="disarmPenalty" value="{{value}}" {{#if selected}}checked{{/if}} />
              <span>{{label}}</span>
            </label>
            {{/each}}
          </div>
        </div>
      </div>

      <div class="skj-roll-dialog__detail skj-attack-roll-dialog__detail skj-attack-roll-dialog__detail--stun" data-augment-detail="stun" hidden>
        <label>{{localize "AOV_SKJALDBORG.AttackDialog.StunLocation"}}</label>
        <select name="stunLocationId">
          {{#each stunLocations}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <label>{{localize "AOV_SKJALDBORG.AttackDialog.StunPenalty"}}</label>
        <div class="skj-attack-roll-dialog__readonly skj-attack-roll-dialog__readonly--penalty">{{stunPenaltyLabel}}</div>
      </div>

      <div class="skj-roll-dialog__detail skj-roll-dialog__detail--custom skj-attack-roll-dialog__detail skj-attack-roll-dialog__detail--custom" data-augment-detail="custom" hidden>
        <label>{{localize "AOV_SKJALDBORG.AttackDialog.Custom"}}</label>
        <input type="text" name="customAugmentReason" placeholder="{{localize "AOV_SKJALDBORG.AttackDialog.CustomReason"}}" />
        <input type="number" name="customAugmentValue" value="0" step="1" />
      </div>
    </section>

    <div class="skj-roll-dialog__footer skj-attack-roll-dialog__actions">
      <button type="button" class="skj-roll-dialog__action skj-attack-roll-dialog__roll-button" data-action="submitAttack" {{#unless hasTargets}}disabled{{/unless}}>
        <i class="fa-solid fa-dice" aria-hidden="true"></i>
        <span>{{localize "AOV_SKJALDBORG.AttackDialog.RollAttack"}}</span>
      </button>
    </div>
  </section>
</div>
